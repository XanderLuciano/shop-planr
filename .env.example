# Database
DB_TYPE=sqlite
DB_PATH=./data/shop_erp.db

# Jira Integration (optional — disabled by default)
JIRA_BASE_URL=https://jira.example.com
JIRA_PROJECT_KEY=PI
JIRA_USERNAME=
JIRA_API_TOKEN=

# Proxy trust (set to "true" only if the app sits behind a trusted reverse proxy)
# When enabled, rate limiting will use the first IP from x-forwarded-for.
# When disabled (default), rate limiting uses the socket remoteAddress only.
TRUST_PROXY=false

# Screenshots (npm run screenshots)
SCREENSHOT_USER=SAMPLE-Sarah
SCREENSHOT_PIN=0000

# n8n Integration (optional — for webhook automations)
# Self-hosted n8n instance URL and API key
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
